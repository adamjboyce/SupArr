#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# SupArr Deploy — Double-click launcher
# Finds Python 3.7+, installs it if missing, launches the deploy GUI.
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Find Python ───────────────────────────────────────────────────────────────

find_python() {
    for cmd in python3 python; do
        if command -v "$cmd" &>/dev/null; then
            ver=$("$cmd" -c "import sys; print(sys.version_info[:2] >= (3,7))" 2>/dev/null)
            if [ "$ver" = "True" ]; then
                echo "$cmd"
                return 0
            fi
        fi
    done
    return 1
}

PYTHON=$(find_python) || PYTHON=""

# ── Install Python if missing ─────────────────────────────────────────────────

if [ -z "$PYTHON" ]; then
    echo "Python 3.7+ not found. Installing..."
    echo ""

    if command -v apt-get &>/dev/null; then
        sudo apt-get update -qq && sudo apt-get install -y python3
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y python3
    elif command -v pacman &>/dev/null; then
        sudo pacman -Sy --noconfirm python
    elif command -v zypper &>/dev/null; then
        sudo zypper install -y python3
    elif command -v brew &>/dev/null; then
        brew install python3
    else
        echo "ERROR: Could not detect package manager."
        echo "Install Python 3.7+ manually, then re-run this script."
        read -rp "Press Enter to exit..."
        exit 1
    fi

    # Re-detect after install
    PYTHON=$(find_python) || PYTHON=""
    if [ -z "$PYTHON" ]; then
        echo "ERROR: Python install succeeded but python3 still not found in PATH."
        read -rp "Press Enter to exit..."
        exit 1
    fi

    echo ""
    echo "Python installed: $($PYTHON --version)"
    echo ""
fi

# ── Launch ────────────────────────────────────────────────────────────────────

exec "$PYTHON" "$SCRIPT_DIR/deploy.py"
